{
  "manifest_version": 3,
  "version": "1.0",
  "name": "YT Study Timer",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "notifications",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "js": [
        "content.js"
      ]
    }
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ]
}